# OpenClaw-TZ example environment variables
# Copy this file only if you have your own local bootstrap process.
# Most OpenClaw runtime settings still live in ~/.openclaw/openclaw.json

# Example model service
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=replace_me

# Optional Telegram bot
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOW_FROM=123456789

# Optional Gateway
OPENCLAW_GATEWAY_PORT=18789
